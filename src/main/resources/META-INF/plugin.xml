<idea-plugin>
    <id>com.github.fangzc.ai-commit-message</id>
    <name>Commit Message(AI)</name>
    <vendor>fangzc</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.vcs</depends>
    <depends>Git4Idea</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- 应用级服务（所有项目共享配置） -->
        <applicationService serviceImplementation="com.github.fangzc.aicommit.settings.PluginSettings"/>

        <!-- Settings 页面（应用级，位于 Settings → Tools → Commit Message(AI)） -->
        <applicationConfigurable
                parentId="tools"
                instance="com.github.fangzc.aicommit.settings.PluginSettingsConfigurable"
                id="com.github.fangzc.aicommit.settings"
                displayName="Commit Message(AI)"/>

        <!-- 通知组 -->
        <notificationGroup id="AiCommit.Notification"
                           displayType="BALLOON"/>
    </extensions>

    <actions>
        <action id="AiCommit.Generate"
                class="com.github.fangzc.aicommit.action.GenerateCommitMessageAction"
                text="Generate AI Commit Message"
                description="Generate commit message using AI based on selected changes"
                icon="/icons/generate.svg">
            <add-to-group group-id="Vcs.MessageActionGroup" anchor="first"/>
        </action>
    </actions>
</idea-plugin>
